# Copy to .env before starting speech-service.

ASR_PROVIDER=qwen3_asr
ASR_MODEL=/root/autodl-tmp/a22/models/Qwen3-ASR-1.7B
ASR_LANGUAGE=Chinese
ASR_DEVICE=cuda:0
ASR_WARMUP_ENABLED=true

# Speech emotion recognition
SER_ENABLED=true
SER_PROVIDER=emotion2vec_plus_base
SER_MODEL=/root/autodl-tmp/a22/models/emotion2vec_plus_base
SER_DEVICE=cuda:0
SER_HUB=ms
SER_TOP_K=3
SER_MIN_CONFIDENCE=0.2
SER_WARMUP_ENABLED=true

# Used only when ASR_PROVIDER=qwen3_asr
QWEN_ASR_USE_FLASH_ATTN=true
QWEN_ASR_USE_ITN=false

# Robot TTS
TTS_PROVIDER=cosyvoice
TTS_MODEL=/root/autodl-tmp/a22/models/CosyVoice-300M-Instruct
TTS_REPO_PATH=
TTS_DEVICE=cuda:0
TTS_MODE=cosyvoice_300m_instruct
TTS_WARMUP_ENABLED=false
TTS_ALLOW_MOCK_FALLBACK=true
TTS_SPEED=1.0
TTS_SAMPLE_RATE=22050

TMP_DIR=/root/autodl-tmp/a22/tmp/speech
