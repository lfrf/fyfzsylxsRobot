# Copy to .env before starting vision-service.

TMP_DIR=/root/autodl-tmp/a22/tmp/vision

VISION_EXTRACTOR_MODE=qwen2_5_vl
VISION_MODEL=/root/autodl-tmp/a22/models/Qwen2.5-VL-7B-Instruct
VISION_DEVICE=cuda:0
VISION_FRAME_INPUT_MODE=event_window_keyframes
VISION_DTYPE=float16
VISION_MAX_NEW_TOKENS=192
VISION_WARMUP_ENABLED=true

VISION_RING_BUFFER_ENABLED=true
VISION_RING_BUFFER_MAX_FRAMES=120
VISION_RING_BUFFER_MAX_AGE_MS=30000
VISION_RING_BUFFER_WINDOW_DEFAULT_MS=6000
VISION_RING_BUFFER_WINDOW_MAX_FRAMES=10

# Face emotion recognition (enet_b2_7)
FER_ENABLED=true
FER_PROVIDER=hsemotion
FER_MODEL_NAME=enet_b2_7
FER_DEVICE=cpu
FER_DETECTOR=haar
FER_MAX_FRAMES=4
FER_MIN_CONFIDENCE=0.2
FER_WARMUP_ENABLED=true
# Required by hsemotion checkpoints on torch>=2.6 (trusted model source only).
FER_FORCE_NO_WEIGHTS_ONLY_LOAD=true

# Face identity recognition. Mock is deterministic and does not require model files.
FACE_RECOGNITION_PROVIDER=mock
FACE_DB_DIR=remote/vision-service/data/faces
FACE_MATCH_THRESHOLD=0.6
FACE_CREATE_UNKNOWN=true
FACE_STORE_RAW_IMAGES=false
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640,640
INSIGHTFACE_CTX_ID=-1
